{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Client",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/client",
            "args": [
                "${workspaceFolder}/tests/test_client/data/client_file.txt",
                "8080"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake_build"
        },
        {
            "name": "Debug Server",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/server",
            "args": [
                "${workspaceFolder}/test_data_files/config.json",
                "8080"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake_build"
        },
        {
            "name": "Debug Test for Server",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/tests/server_tests",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake_build"
        },
        {
            "name": "Debug Statistics",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/statistics",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cmake_build"
        }
    ]
}